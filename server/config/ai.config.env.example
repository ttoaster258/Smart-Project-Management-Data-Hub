# AI 服务配置文件示例
# 请复制此文件为 ai.config.env 并填写你的真实 API Key

# ============================================
# 阿里云百炼 API 配置（Anthropic 兼容接口）
# ============================================

# API Base URL（阿里云百炼 Anthropic 兼容接口）
ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic

# API Key（请填写你的真实 API Key）
# 格式示例：sk-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=

# 模型名称
ANTHROPIC_MODEL=glm-5

# ============================================
# 报告生成配置
# ============================================

# 报告生成超时时间（毫秒）
REPORT_GENERATION_TIMEOUT=60000

# 最大输出 token 数
MAX_OUTPUT_TOKENS_WEEKLY=6000
MAX_OUTPUT_TOKENS_MONTHLY=10000

# 温度参数（0-1，越低越稳定）
TEMPERATURE=0.3