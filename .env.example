# ============================================
# Smart Project Management Data Hub
# Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# Backend Server Configuration
# ============================================

# Server port (default: 4000)
PORT=4000

# Environment mode
NODE_ENV=development

# ============================================
# Frontend Configuration (Vite)
# ============================================

# API base URL for frontend requests
# In development, Vite proxy handles this automatically
# In production, set to your backend server URL
VITE_API_URL=http://localhost:4000

# ============================================
# AI Service Configuration (Optional)
# ============================================
# For intelligent report generation feature
# Leave empty if not using AI features

# AI API Base URL (Anthropic-compatible endpoint)
ANTHROPIC_BASE_URL=

# AI API Key
ANTHROPIC_API_KEY=

# AI Model name
ANTHROPIC_MODEL=glm-5

# Report generation timeout (milliseconds)
REPORT_GENERATION_TIMEOUT=60000

# Max output tokens
MAX_OUTPUT_TOKENS_WEEKLY=6000
MAX_OUTPUT_TOKENS_MONTHLY=10000

# Temperature parameter (0-1, lower = more stable)
TEMPERATURE=0.3

# ============================================
# Authentication Configuration
# ============================================

# JWT secret key (generate a secure random string for production)
JWT_SECRET=your-secure-jwt-secret-key-here

# JWT expiration time (e.g., 24h, 7d)
JWT_EXPIRES_IN=24h

# ============================================
# Admin Configuration
# ============================================

# Default admin username
ADMIN_USERNAME=admin

# Default admin password (change in production!)
ADMIN_PASSWORD=admin123